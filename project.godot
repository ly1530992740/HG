; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

"ï»¿config_version"=5

[application]

config/name="Tiny Sword survival island"
run/main_scene="uid://dtkqopu3xic5n"
config/features=PackedStringArray("4.7", "Mobile")
run/max_fps=60
boot_splash/show_image=false
boot_splash/use_filter=false
config/icon="res://icon.svg"

[autoload]

Global="*res://global.gd"
BuildingManager="*res://buildings/unit construction/building_manager.gd"
GlobalPlayer="*res://global_player.gd"
TargetManager="*res://target_manager.gd"
tutomanager="*res://tutomanager.gd"

[display]

window/size/viewport_width=1100
window/size/viewport_height=690
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/scale=1.5
mouse_cursor/custom_image="uid://demgxhdh76j4o"

[editor_plugins]

enabled=PackedStringArray("res://addons/goap/plugin.cfg")

[file_customization]

folder_colors={
"res://Main/": "green",
"res://loadings/": "yellow",
"res://unit/": "orange",
"res://unit/pawn_/": "blue"
}

